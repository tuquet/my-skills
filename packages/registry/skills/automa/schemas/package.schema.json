{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Automa Package Schema",
  "anyOf": [
    {
      "type": "object",
      "description": "Format for full Automa Packages",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string" }
            },
            "required": ["id", "name"]
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            },
            "required": ["id", "name"]
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "asBlock": { "type": "boolean" }
          },
          "required": ["asBlock"]
        },
        "data": {
          "type": "object",
          "properties": {
            "nodes": { "type": "array" },
            "edges": { "type": "array" }
          },
          "required": ["nodes", "edges"]
        }
      },
      "required": ["name", "inputs", "outputs", "settings", "data"]
    },
    {
      "type": "object",
      "description": "Format for clipboard / copy-pasted automa-blocks",
      "properties": {
        "name": {
          "type": "string",
          "const": "automa-blocks"
        },
        "data": {
          "type": "object",
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "position": {
                    "type": "object",
                    "properties": {
                      "x": { "type": "number" },
                      "y": { "type": "number" }
                    },
                    "required": ["x", "y"]
                  }
                },
                "required": ["position"]
              }
            },
            "edges": { "type": "array" }
          },
          "required": ["nodes", "edges"]
        }
      },
      "required": ["name", "data"]
    }
  ]
}
