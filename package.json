{
  "name": "skills-monorepo",
  "private": true,
  "workspaces": [
    "packages/registry",
    "packages/cli"
  ],
  "scripts": {
    "cli": "node packages/cli/bin/index.js",
    "publish:registry": "npm publish -w packages/registry",
    "publish:cli": "npm publish -w packages/cli",
    "publish:all": "npm run publish:registry && npm run publish:cli"
  },
  "engines": {
    "node": ">=18"
  }
}
