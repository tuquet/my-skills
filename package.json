{
  "name": "skills-monorepo",
  "private": true,
  "scripts": {
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "cli": "node packages/cli/bin/index.js",
    "publish:registry": "pnpm publish -w packages/registry",
    "publish:cli": "pnpm publish -w packages/cli",
    "publish:all": "pnpm run publish:registry && pnpm run publish:cli"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
